# Server
PORT=3000
SERVER_ORIGIN=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000

# Database (use one of the options below)
# Option 1: SQLite (local development)
# USE_SQLITE=true
# DATABASE_SQLITE_PATH=schedley.sqlite

# Option 2: PostgreSQL (URL)
# USE_SQLITE=false
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_SSL=true

# Option 3: PostgreSQL (individual vars)
# USE_SQLITE=false
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_DATABASE=schedley
# DATABASE_SSL=false

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d

# Google OAuth (optional; omit to disable Google sign-in)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
# GOOGLE_CALENDAR_CALLBACK_URL=http://localhost:3000/api/integration/google/callback
